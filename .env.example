# Runtime
PORT=8080

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Deployment
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
# Optional: preferred Secret Manager secret reference for deploys
# OPENROUTER_API_KEY_SECRET=projects/your-gcp-project-id/secrets/openrouter-api-key:latest
